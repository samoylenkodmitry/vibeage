{
  "extensions": [
    ".js",
    ".jsx",
    ".mjs",
    ".cjs",
    ".ts",
    ".tsx"
  ],
  "ignoredDirs": [
    ".git",
    ".next",
    "coverage",
    "dist",
    "node_modules",
    "out",
    "public"
  ],
  "budgets": {
    "maxFileLines": 700,
    "maxFunctionLines": 100,
    "maxFunctionParams": 6,
    "maxNestingDepth": 5
  },
  "legacyFiles": {}
}
