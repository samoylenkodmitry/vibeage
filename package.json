{
  "name": "vibeage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --max-warnings=0",
    "typecheck": "pnpm run typecheck:client && pnpm run typecheck:server",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "check:scripts": "bash -n scripts/setup-server.sh && bash -n scripts/setup-client.sh && bash -n scripts/auto-migrate.sh && bash -n scripts/deploy-production.sh && bash -n scripts/deploy-from-local.sh && bash -n scripts/rollback-production.sh && bash -n scripts/backup-postgres.sh && bash -n scripts/test-postgres-restore.sh && bash -n scripts/install-postgres-backup-cron.sh",
    "check:maintainability": "node scripts/check-maintainability.mjs",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run check:scripts && pnpm run check:maintainability && pnpm test && pnpm run build:server && pnpm run build && pnpm run test:e2e",
    "deploy:production": "scripts/deploy-from-local.sh",
    "deploy:rollback": "scripts/rollback-production.sh",
    "db:backup": "scripts/backup-postgres.sh",
    "db:backup:install-cron": "scripts/install-postgres-backup-cron.sh",
    "db:restore:test": "scripts/test-postgres-restore.sh",
    "build:server": "tsc -p tsconfig.server.json",
    "start:server": "node --experimental-specifier-resolution=node dist/server/server.js",
    "dev:server": "tsx watch server/server.ts",
    "dev:all": "concurrently \"pnpm run dev\" \"pnpm run dev:server\"",
    "dev:db": "./dev.sh",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "generate-docs": "tsx generate-project-doc.ts"
  },
  "dependencies": {
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/rapier": "^2.2.0",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/uuid": "^11.0.0",
    "bufferutil": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "glob": "^11.0.2",
    "immer": "^10.2.0",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.11",
    "next": "15.5.16",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reselect": "^5.1.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.184.0",
    "utf-8-validate": "^6.0.6",
    "uuid": "^11.1.1",
    "ws": "^8.20.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^15.5.16",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/nanoid": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.16",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.2.4"
  }
}
