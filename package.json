{
  "name": "vibeage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:vite-client": "vite --config apps/client/vite.config.ts",
    "build": "next build",
    "build:vite-client": "vite build --config apps/client/vite.config.ts",
    "preview:vite-client": "vite preview --config apps/client/vite.config.ts",
    "start": "next start",
    "lint": "next lint --max-warnings=0",
    "typecheck": "pnpm run typecheck:client && pnpm run typecheck:server",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "check:scripts": "bash -n scripts/setup-server.sh && bash -n scripts/setup-client.sh && bash -n scripts/auto-migrate.sh && bash -n scripts/deploy-production.sh && bash -n scripts/deploy-from-local.sh && bash -n scripts/rollback-production.sh && bash -n scripts/backup-postgres.sh && bash -n scripts/test-postgres-restore.sh && bash -n scripts/install-postgres-backup-cron.sh && bash -n scripts/health-production.sh",
    "check:maintainability": "node scripts/check-maintainability.mjs",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run check:scripts && pnpm run check:maintainability && pnpm test && pnpm run build:server && pnpm run build && pnpm run build:vite-client && pnpm run test:e2e && pnpm run test:e2e:vite",
    "deploy:production": "scripts/deploy-from-local.sh",
    "deploy:rollback": "scripts/rollback-production.sh",
    "health:production": "scripts/health-production.sh",
    "db:backup": "scripts/backup-postgres.sh",
    "db:backup:install-cron": "scripts/install-postgres-backup-cron.sh",
    "db:restore:test": "scripts/test-postgres-restore.sh",
    "build:server": "tsc -p tsconfig.server.json",
    "start:server": "node --experimental-specifier-resolution=node dist/server/server.js",
    "dev:server": "tsx watch server/server.ts",
    "dev:all": "concurrently \"pnpm run dev\" \"pnpm run dev:server\"",
    "dev:db": "./dev.sh",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:vite": "playwright test -c playwright.vite.config.ts",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "generate-docs": "tsx generate-project-doc.ts"
  },
  "dependencies": {
    "@react-three/cannon": "^6.6.0",
    "@react-three/drei": "^10.0.5",
    "@react-three/fiber": "^9.1.1",
    "@react-three/rapier": "^2.0.0",
    "@types/express": "^5.0.2",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^10.0.0",
    "bufferutil": "^4.0.9",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "framer-motion": "^12.6.3",
    "glob": "^11.0.2",
    "immer": "^10.1.1",
    "morgan": "^1.10.0",
    "nanoid": "^5.1.5",
    "next": "15.2.4",
    "pg": "^8.16.0",
    "pg-hstore": "^2.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reselect": "^5.1.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "three": "^0.175.0",
    "utf-8-validate": "^6.0.5",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "zod": "3.24.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.24.0",
    "@next/eslint-plugin-next": "^15.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/nanoid": "^3.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.15.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
