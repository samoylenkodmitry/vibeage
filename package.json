{
  "name": "vibeage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite --config apps/client/vite.config.ts",
    "dev:vite-client": "vite --config apps/client/vite.config.ts",
    "build": "pnpm run build:vite-client",
    "build:vite-client": "vite build --config apps/client/vite.config.ts",
    "preview:vite-client": "vite preview --config apps/client/vite.config.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "pnpm run typecheck:client && pnpm run typecheck:server",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:packages": "tsc -p tsconfig.packages.strict.json --noEmit",
    "check:scripts": "bash -n scripts/setup-server.sh && bash -n scripts/setup-client.sh && bash -n scripts/auto-migrate.sh && bash -n scripts/deploy-production.sh && bash -n scripts/deploy-from-local.sh && bash -n scripts/rollback-production.sh && bash -n scripts/backup-postgres.sh && bash -n scripts/pull-postgres-backup-local.sh && bash -n scripts/test-postgres-restore.sh && bash -n scripts/health-production.sh && bash -n scripts/diagnose-production.sh",
    "content:check": "NODE_OPTIONS=--no-deprecation tsx scripts/check-content.ts",
    "content:graph": "NODE_OPTIONS=--no-deprecation tsx scripts/content-graph.ts",
    "content:audit": "NODE_OPTIONS=--no-deprecation tsx scripts/content-audit.ts",
    "content:audit:check": "NODE_OPTIONS=--no-deprecation tsx scripts/content-audit.ts --check",
    "balance:report": "NODE_OPTIONS=--no-deprecation tsx scripts/balance-report.ts",
    "check:maintainability": "node scripts/check-maintainability.mjs",
    "check:server": "node scripts/check-scope.mjs server",
    "check:client": "node scripts/check-scope.mjs client",
    "check:protocol": "node scripts/check-scope.mjs protocol",
    "check:content": "node scripts/check-scope.mjs content",
    "check:deadcode": "knip --no-progress --include files,dependencies,unlisted,binaries,unresolved,duplicates",
    "deadcode:report": "knip --no-progress --reporter compact --max-show-issues 200 --no-exit-code",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run typecheck:packages && pnpm run check:scripts && pnpm run check:maintainability && pnpm run check:deadcode && pnpm run content:check && pnpm run content:graph && pnpm run content:audit:check && pnpm test && pnpm run build:server && pnpm run build && pnpm run test:e2e",
    "deploy:production": "scripts/deploy-from-local.sh",
    "deploy:rollback": "scripts/rollback-production.sh",
    "diagnose:production": "bash scripts/diagnose-production.sh",
    "health:production": "scripts/health-production.sh",
    "smoke:production": "node scripts/smoke-production.mjs",
    "db:backup": "scripts/backup-postgres.sh",
    "db:backup:pull-local": "scripts/pull-postgres-backup-local.sh",
    "db:restore:test": "scripts/test-postgres-restore.sh",
    "build:server": "tsc -p tsconfig.server.json",
    "start:server": "node --experimental-specifier-resolution=node dist/apps/server/src/main.js",
    "dev:server": "tsx watch apps/server/src/main.ts",
    "dev:all": "concurrently \"pnpm run dev\" \"pnpm run dev:server\"",
    "dev:db": "./dev.sh",
    "test": "vitest run",
    "test:e2e": "env -u NO_COLOR playwright test",
    "test:e2e:vite": "env -u NO_COLOR playwright test -c playwright.vite.config.ts",
    "test:e2e:production": "env -u NO_COLOR playwright test -c playwright.production.config.ts",
    "measure:baseline": "node scripts/measure-baseline.mjs",
    "measure:check": "pnpm run build && BASELINE_START_LOCAL=1 BASELINE_ENFORCE=1 BASELINE_SKIP_BROWSER_FPS=1 node scripts/measure-baseline.mjs",
    "measure:browser": "pnpm run build && BASELINE_START_LOCAL=1 node scripts/measure-baseline.mjs",
    "load:inprocess": "tsx scripts/load-test-inprocess.ts",
    "load:sweep": "tsx scripts/load-test-sweep.ts",
    "load:baseline": "LOAD_PLAYERS=50 LOAD_TICKS=600 LOAD_COMBAT=1 tsx scripts/load-test-inprocess.ts",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "generate-docs": "tsx generate-project-doc.ts"
  },
  "dependencies": {
    "@colyseus/core": "0.17.43",
    "@colyseus/schema": "4.0.25",
    "@colyseus/sdk": "0.17.42",
    "@colyseus/ws-transport": "0.17.13",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "kysely": "^0.29.0",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.11",
    "pg": "^8.20.0",
    "postprocessing": "^6.39.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "knip": "^6.13.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "bufferutil",
      "msgpackr-extract",
      "utf-8-validate"
    ]
  }
}
